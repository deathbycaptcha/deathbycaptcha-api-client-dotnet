# DeathByCaptcha integration-test credentials
# Copy this file to .env and fill in your real values.
# The .env file is gitignored and will never be committed.
#
# Alternative: export these as shell environment variables before running tests.
#   export DBC_USERNAME=your_username
#   export DBC_PASSWORD=your_password
#
# Alternative: use dotnet user-secrets (stored outside the repo):
#   dotnet user-secrets set DBC_USERNAME your_username --project DeathByCaptcha/DeathByCaptcha.Tests
#   dotnet user-secrets set DBC_PASSWORD your_password --project DeathByCaptcha/DeathByCaptcha.Tests
#
# Optional: enable slow/full API-surface integration tests (default is disabled)
#   DBC_INTEGRATION_FULL=true

DBC_USERNAME='your_username'
DBC_PASSWORD='your_password'
DBC_INTEGRATION_FULL=false
